{
  "manifest_version": 3,
  "name": "ZendIQ Lite",
  "version": "1.0.2",
  "description": "Free Solana swap guardian. Warns you before signing on Jupiter, Raydium & Pump.fun. Token risk scan + wallet security checker.",
  "homepage_url": "https://zendiq.ai",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://api.rugcheck.xyz/*",
    "https://api.dexscreener.com/*",
    "https://api.geckoterminal.com/*",
    "https://api.mainnet-beta.solana.com/*",
    "https://solana.publicnode.com/*",
    "https://zendiq-backend.onrender.com/*",
    "https://jup.ag/*",
    "https://*.jup.ag/*",
    "https://raydium.io/*",
    "https://*.raydium.io/*",
    "https://pump.fun/*",
    "https://*.pump.fun/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://jup.ag/*",
        "https://*.jup.ag/*",
        "https://raydium.io/*",
        "https://*.raydium.io/*",
        "https://pump.fun/*",
        "https://*.pump.fun/*"
      ],
      "js": [
        "src/scripts/page-config.js",
        "src/utils/extraction.js",
        "src/utils/scoring.js",
        "src/scripts/page-interceptor.js",
        "src/scripts/page-wallet.js",
        "src/scripts/page-security.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://jup.ag/*",
        "https://*.jup.ag/*",
        "https://raydium.io/*",
        "https://*.raydium.io/*",
        "https://pump.fun/*",
        "https://*.pump.fun/*"
      ],
      "js": ["src/scripts/bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "src/ui/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/icon-48.png"],
      "matches": [
        "https://jup.ag/*",
        "https://*.jup.ag/*",
        "https://raydium.io/*",
        "https://*.raydium.io/*",
        "https://pump.fun/*",
        "https://*.pump.fun/*"
      ]
    }
  ]
}
